---
import Layout from '../layouts/Layout.astro'
import Contact from '../components/sections/Contact.tsx'

const title = "Contact Frame Foundry - Start Your Creative Project"
const description = "Get in touch with Frame Foundry to discuss your creative project. We'd love to hear about your vision and how we can bring it to life."
---

<Layout title={title} description={description} url="https://framefoundry.io/contact">
  <div class="pt-20">
    <Contact client:load />
  </div>
</Layout>