---
import '../styles/global.css'
import Header from '../components/navigation/Header.tsx'
import Hero from '../components/sections/Hero.tsx'
import Services from '../components/sections/Services.tsx'
import Process from '../components/sections/Process.tsx'
import Contact from '../components/sections/Contact.tsx'
import { ContinuousFrame } from '../components/ui/ContinuousFrame.tsx'
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Frame Foundry - Creative Agency</title>
		<meta name="description" content="Frame Foundry is a creative agency specializing in brand identity, digital design, and innovative creative solutions. We craft experiences that captivate, inspire, and drive results." />
		<meta property="og:title" content="Frame Foundry - Creative Agency" />
		<meta property="og:description" content="Frame Foundry is a creative agency specializing in brand identity, digital design, and innovative creative solutions." />
		<meta property="og:url" content="https://framefoundry.io" />
		<meta property="og:type" content="website" />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
		<style>
			html {
				scroll-behavior: smooth;
			}
		</style>
	</head>
	<body class="font-montserrat antialiased relative text-body">
		<!-- Global continuous frame -->
		<div class="fixed inset-0 pointer-events-none z-50">
			<ContinuousFrame client:load margin={20} opacity={0.15} />
		</div>
		
		<Header client:load />
		
		<!-- Hero Section -->
		<section id="home" class="min-h-screen">
			<Hero client:load />
		</section>

		<!-- Work Section -->
		<section id="work" class="py-24 bg-slate-900 relative">
			<ContinuousFrame client:load margin={60} opacity={0.1} zIndex={1} />
			<div class="max-w-7xl mx-auto px-4 relative z-10">
				<div class="text-center mb-16">
					<h2 class="text-4xl md:text-6xl font-poppins font-bold text-white mb-8 tracking-tight">Featured Work</h2>
					<p class="text-xl text-gray-300 max-w-3xl mx-auto font-inter leading-relaxed">
						A selection of our most impactful projects across industries and creative disciplines.
					</p>
				</div>

				<!-- TechFlow Solutions Case Study -->
				<div class="mb-16 bg-black/40 rounded-lg overflow-hidden border border-gray-800 hover:border-purple-500/50 transition-all duration-300 group">
					<div class="grid grid-cols-1 lg:grid-cols-2 gap-0">
						<div class="p-8 lg:p-12 flex flex-col justify-center">
							<div class="inline-flex items-center gap-2 bg-purple-100/10 text-purple-300 px-3 py-1 rounded-md text-sm font-medium mb-6 w-fit">
								Brand Transformation
							</div>
							<h3 class="text-4xl font-poppins font-bold text-white mb-4 tracking-tight">TechFlow Solutions</h3>
							<p class="text-xl text-gray-300 mb-6 font-inter leading-relaxed">
								Complete brand transformation for a B2B SaaS platform, from strategy to digital implementation.
							</p>
							<div class="space-y-3 mb-8">
								<div class="flex items-center text-gray-300">
									<span class="w-2 h-2 bg-purple-500 rounded-full mr-3"></span>
									<span>450% increase in website engagement</span>
								</div>
								<div class="flex items-center text-gray-300">
									<span class="w-2 h-2 bg-purple-500 rounded-full mr-3"></span>
									<span>280% improvement in lead generation</span>
								</div>
								<div class="flex items-center text-gray-300">
									<span class="w-2 h-2 bg-purple-500 rounded-full mr-3"></span>
									<span>95% brand recognition increase</span>
								</div>
							</div>
							<div class="flex flex-wrap gap-2 mb-8">
								<span class="bg-gray-800 text-gray-300 px-3 py-1 rounded-md text-sm">Brand Strategy</span>
								<span class="bg-gray-800 text-gray-300 px-3 py-1 rounded-md text-sm">Visual Identity</span>
								<span class="bg-gray-800 text-gray-300 px-3 py-1 rounded-md text-sm">Web Design</span>
								<span class="bg-gray-800 text-gray-300 px-3 py-1 rounded-md text-sm">Development</span>
							</div>
						</div>
						<div class="bg-gradient-to-br from-purple-600 via-pink-600 to-orange-600 p-12 flex items-center justify-center">
							<div class="text-center">
								<div class="text-6xl font-bold text-white mb-4">TF</div>
								<div class="text-xl text-white/80">TechFlow Solutions</div>
							</div>
						</div>
					</div>
				</div>

				<!-- Project Grid -->
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
					
					<!-- Project 1: Wellness Brand -->
					<div class="bg-black/40 rounded-lg overflow-hidden border border-gray-800 hover:border-pink-500/50 transition-all duration-300 group">
						<div class="aspect-video bg-gradient-to-br from-green-500 via-teal-500 to-blue-500 flex items-center justify-center">
							<div class="text-4xl font-bold text-white">ZW</div>
						</div>
						<div class="p-6">
							<div class="inline-flex items-center gap-2 bg-green-100/10 text-green-300 px-3 py-1 rounded-md text-sm font-medium mb-4">
								Wellness & Health
							</div>
							<h3 class="text-xl font-poppins font-bold text-white mb-3">ZenWell Wellness</h3>
							<p class="text-gray-300 mb-4 font-inter">Holistic brand identity and digital platform for a modern wellness company focused on mental health and mindfulness.</p>
							<div class="flex flex-wrap gap-1 mb-4">
								<span class="bg-gray-800 text-gray-400 px-2 py-1 rounded-sm text-xs">Brand Identity</span>
								<span class="bg-gray-800 text-gray-400 px-2 py-1 rounded-sm text-xs">App Design</span>
								<span class="bg-gray-800 text-gray-400 px-2 py-1 rounded-sm text-xs">Content Strategy</span>
							</div>
						</div>
					</div>

					<!-- Project 2: Fashion E-commerce -->
					<div class="bg-black/40 rounded-lg overflow-hidden border border-gray-800 hover:border-orange-500/50 transition-all duration-300 group">
						<div class="aspect-video bg-gradient-to-br from-pink-500 via-red-500 to-orange-500 flex items-center justify-center">
							<div class="text-4xl font-bold text-white">LC</div>
						</div>
						<div class="p-6">
							<div class="inline-flex items-center gap-2 bg-pink-100/10 text-pink-300 px-3 py-1 rounded-md text-sm font-medium mb-4">
								Fashion & Retail
							</div>
							<h3 class="text-xl font-poppins font-bold text-white mb-3">Luna Collective</h3>
							<p class="text-gray-300 mb-4 font-inter">Luxury fashion e-commerce platform with immersive product experiences and AI-powered styling recommendations.</p>
							<div class="flex flex-wrap gap-1 mb-4">
								<span class="bg-gray-800 text-gray-400 px-2 py-1 rounded-sm text-xs">E-commerce</span>
								<span class="bg-gray-800 text-gray-400 px-2 py-1 rounded-sm text-xs">UX/UI</span>
								<span class="bg-gray-800 text-gray-400 px-2 py-1 rounded-sm text-xs">AR Integration</span>
							</div>
						</div>
					</div>

					<!-- Project 3: Fintech Startup -->
					<div class="bg-black/40 rounded-lg overflow-hidden border border-gray-800 hover:border-blue-500/50 transition-all duration-300 group">
						<div class="aspect-video bg-gradient-to-br from-blue-600 via-purple-600 to-indigo-600 flex items-center justify-center">
							<div class="text-4xl font-bold text-white">FP</div>
						</div>
						<div class="p-6">
							<div class="inline-flex items-center gap-2 bg-blue-100/10 text-blue-300 px-3 py-1 rounded-md text-sm font-medium mb-4">
								Fintech & Finance
							</div>
							<h3 class="text-xl font-poppins font-bold text-white mb-3">FlowPay</h3>
							<p class="text-gray-300 mb-4 font-inter">Next-generation payment platform brand identity and mobile app design focused on seamless user experiences.</p>
							<div class="flex flex-wrap gap-1 mb-4">
								<span class="bg-gray-800 text-gray-400 px-2 py-1 rounded-sm text-xs">Mobile App</span>
								<span class="bg-gray-800 text-gray-400 px-2 py-1 rounded-sm text-xs">Brand Design</span>
								<span class="bg-gray-800 text-gray-400 px-2 py-1 rounded-sm text-xs">Security UX</span>
							</div>
						</div>
					</div>

				</div>
			</div>
		</section>

		<!-- Services Section -->
		<section id="services" class="min-h-screen relative">
			<ContinuousFrame client:load margin={60} opacity={0.1} zIndex={1} />
			<div class="relative z-10">
				<Services client:load />
			</div>
		</section>

		<!-- Process Section -->
		<section id="process" class="min-h-screen relative">
			<ContinuousFrame client:load margin={60} opacity={0.1} zIndex={1} />
			<div class="relative z-10">
				<Process client:load />
			</div>
		</section>

		<!-- Contact Section -->
		<section id="contact" class="min-h-screen relative">
			<ContinuousFrame client:load margin={60} opacity={0.1} zIndex={1} />
			<div class="relative z-10">
				<Contact client:load />
			</div>
		</section>
	</body>
</html>